---
interface Props {
	tags: Map<string, number>;
}

const { tags } = Astro.props;

const sorted = [...tags.entries()].sort((a, b) => a[0].localeCompare(b[0]));
const counts = [...tags.values()];
const minCount = Math.min(...counts);
const maxCount = Math.max(...counts);

function fontSize(count: number): string {
	if (maxCount === minCount) return '0.8rem';
	const scale = (count - minCount) / (maxCount - minCount);
	const size = 0.75 + scale * 0.5;
	return `${size}rem`;
}
---

<div class="tag-cloud">
	{sorted.map(([tag, count]) => (
		<a
			href={`/tags/${encodeURIComponent(tag)}/`}
			class="tag-pill"
			style={`font-size: ${fontSize(count)}`}
		>
			{tag} <span class="tag-count">({count})</span>
		</a>
	))}
</div>

<style>
	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		justify-content: center;
		margin-top: 0.5rem;
	}
	.tag-pill {
		display: inline-block;
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 12%, transparent);
		color: var(--accent-dark, var(--accent));
		text-decoration: none;
		font-weight: 600;
		line-height: 1.4;
		white-space: nowrap;
		transition: background 0.2s ease, color 0.2s ease;
	}
	.tag-pill:hover {
		background: var(--accent);
		color: #fff;
	}
	.tag-count {
		font-weight: 400;
		opacity: 0.7;
		font-size: 0.85em;
	}
</style>
